# ══════════════════════════════════════════════════════════════════════════════
# .env — опциональные переопределения (скопируй в .env если нужно)
#
# Вся конфигурация в config.yml — Docker читает его при старте и
# качает все модели автоматически. Этот файл вообще не нужен
# если только не хочешь переопределить конкретные значения.
# ══════════════════════════════════════════════════════════════════════════════

# переопределить порт хоста (по умолчанию: 8000)
# PORT=8000

# HuggingFace токен — избегает лимитов и позволяет качать закрытые модели
# получи свой на https://huggingface.co/settings/tokens
# HF_TOKEN=hf_...
